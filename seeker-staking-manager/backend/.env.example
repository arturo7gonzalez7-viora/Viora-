# Solana RPC (get free key from helius.dev)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Supabase (get from supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Stripe (optional, for payments - get from stripe.com)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PRICE_ID=price_your_subscription_product_id

# Server
PORT=3001
NODE_ENV=development
